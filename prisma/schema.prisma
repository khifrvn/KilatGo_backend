generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
  MERCHANT
}

enum KycSubject {
  DRIVER
  MERCHANT
}

enum AttendanceStatus {
  PRESENT
  FLAGGED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ComplaintFrom {
  DRIVER
  MERCHANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum DriverStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum ServiceType {
  RIDE
  CAR
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  DRIVER_ARRIVED
  ON_RIDE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  EWALLET
  BANK_TRANSFER
  CARD
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  phone     String     @unique
  name      String
  role      UserRole
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  customer      Customer?
  driver        Driver?
  admin         Admin?
  merchant      Merchant?
  notifications Notification[] @relation("UserNotifications")

  @@map("users")
}

model Customer {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Float    @default(5.0)
  totalRides Int      @default(0) @map("total_rides")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("customers")
}

model Driver {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Data diri / KTP
  nik           String?       @map("nik")
  birthDate     DateTime?     @map("birth_date")
  address       String?       @db.Text @map("address")
  city          String?       @map("city")
  serviceType   ServiceType   @default(RIDE) @map("service_type")

  // SIM
  simType       String?       @map("sim_type")
  simNumber     String?       @map("sim_number")
  simExpiry     DateTime?     @map("sim_expiry")

  // Kendaraan
  vehicleType    String        @map("vehicle_type")
  vehiclePlate   String        @map("vehicle_plate")
  licenseNumber  String        @map("license_number")
  vehicleBrand   String?       @map("vehicle_brand")
  vehicleYear    Int?          @map("vehicle_year")
  vehicleColor   String?       @map("vehicle_color")
  stnkNumber     String?       @map("stnk_number")

  // Rekening & pajak
  bankName      String?       @map("bank_name")
  bankAccount   String?       @map("bank_account")
  bankHolder    String?       @map("bank_holder")
  npwp          String?       @map("npwp")

  // Dokumen (path file privat) & KYC
  ktpPhoto      String?       @map("ktp_photo")
  selfiePhoto   String?       @map("selfie_photo")
  simPhoto      String?       @map("sim_photo")
  stnkPhoto     String?       @map("stnk_photo")
  skckPhoto     String?       @map("skck_photo")
  faceDescriptor String?      @db.Text @map("face_descriptor")
  kycStatus     KycStatus     @default(UNVERIFIED) @map("kyc_status")

  status         DriverStatus  @default(OFFLINE)
  latitude       Float?
  longitude      Float?
  lastLocationAt DateTime?     @map("last_location_at")

  rating     Float   @default(5.0)
  totalRides Int     @default(0) @map("total_rides")
  isApproved Boolean @default(false) @map("is_approved")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders          Order[]
  trackingHistory Tracking[]
  attendances     Attendance[]

  @@map("drivers")
}

// ===== Fase 2: Mitra Usaha (GoFood) =====
model Merchant {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String  @map("business_name")
  category     String?
  ownerName    String  @map("owner_name")
  nik          String?
  phone        String?
  address      String? @db.Text
  city         String?
  latitude     Float?
  longitude    Float?
  operatingHours String? @map("operating_hours")

  // Legalitas & rekening
  npwp        String?
  nib         String? // badan usaha
  siup        String? // badan usaha
  bankName    String? @map("bank_name")
  bankAccount String? @map("bank_account")
  bankHolder  String? @map("bank_holder")

  // Dokumen (path privat) & KYC
  ktpPhoto    String?   @map("ktp_photo")
  outletPhoto String?   @map("outlet_photo")
  npwpPhoto   String?   @map("npwp_photo")
  kycStatus   KycStatus @default(UNVERIFIED) @map("kyc_status")
  isApproved  Boolean   @default(false) @map("is_approved")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  menus MerchantMenu[]

  @@map("merchants")
}

model MerchantMenu {
  id         String   @id @default(uuid())
  merchantId String   @map("merchant_id")
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String
  price       Decimal @db.Decimal(10, 2)
  description String? @db.Text
  category    String?
  photo       String?
  isAvailable Boolean @default(true) @map("is_available")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([merchantId])
  @@map("merchant_menus")
}

// ===== Fase 3: KYC & Absen =====
model KycVerification {
  id          String     @id @default(uuid())
  subjectType KycSubject @map("subject_type")
  subjectId   String     @map("subject_id") // driver.id atau merchant.id

  ocrName        String? @map("ocr_name")
  ocrNik         String? @map("ocr_nik")
  faceMatchScore Float?  @map("face_match_score")
  livenessPassed Boolean? @map("liveness_passed")
  status         KycStatus @default(PENDING)
  provider       String?  // vendor e-KYC (nanti), null = manual
  notes          String?  @db.Text
  verifiedAt     DateTime? @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subjectType, subjectId])
  @@map("kyc_verifications")
}

model Attendance {
  id       String @id @default(uuid())
  driverId String @map("driver_id")
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  latitude    Float
  longitude   Float
  selfiePhoto String?          @map("selfie_photo")
  matchScore  Float?           @map("match_score") // hasil face-match vs selfie KYC (vendor, nanti)
  status      AttendanceStatus @default(PRESENT)

  checkedAt DateTime @default(now()) @map("checked_at")

  @@index([driverId])
  @@map("attendances")
}

// ===== Pengaturan (key-value: komisi, tarif, dll) =====
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ===== Kendala / keluhan driver & mitra =====
model Complaint {
  id         String          @id @default(uuid())
  fromRole   ComplaintFrom   @map("from_role")
  fromUserId String          @map("from_user_id")
  fromName   String?         @map("from_name")
  category   String?
  subject    String
  message    String          @db.Text
  status     ComplaintStatus @default(OPEN)
  adminNote  String?         @db.Text @map("admin_note")

  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([status])
  @@map("complaints")
}

model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique @default(uuid()) @map("order_number")

  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])

  driverId        String?       @map("driver_id")
  driver          Driver?       @relation(fields: [driverId], references: [id])

  pickupLat       Float         @map("pickup_lat")
  pickupLng       Float         @map("pickup_lng")
  pickupAddress   String        @map("pickup_address") @db.Text

  dropoffLat      Float         @map("dropoff_lat")
  dropoffLng      Float         @map("dropoff_lng")
  dropoffAddress  String        @map("dropoff_address") @db.Text

  status          OrderStatus   @default(PENDING)

  distanceKm      Float         @map("distance_km")
  baseFare        Decimal       @map("base_fare") @db.Decimal(10, 2)
  totalFare       Decimal       @map("total_fare") @db.Decimal(10, 2)

  paymentMethod   PaymentMethod @default(CASH) @map("payment_method")

  notes           String?       @db.Text

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  completedAt     DateTime?     @map("completed_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  cancellationReason String?    @map("cancellation_reason") @db.Text

  payment      Payment?
  trackingLogs Tracking[]

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@map("orders")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)

  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

model Tracking {
  id        String   @id @default(uuid())
  orderId   String?  @map("order_id")
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  driverId  String   @map("driver_id")
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([driverId])
  @@map("tracking")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserNotifications")

  title     String
  body      String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

// ===== Log error (API & client) =====
model ErrorLog {
  id         String   @id @default(uuid())
  level      String   @default("ERROR") // ERROR | CLIENT | WARN
  statusCode Int?     @map("status_code")
  message    String   @db.Text
  path       String?
  method     String?
  stack      String?  @db.Text
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("error_logs")
}
