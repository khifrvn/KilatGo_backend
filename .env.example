# Server
PORT=3000
NODE_ENV=development

# Database (MySQL / MariaDB)
DATABASE_URL="mysql://username:password@localhost:3306/kilatgo_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin default credentials (used by seed)
ADMIN_EMAIL=admin@kilatgo.com
ADMIN_PASSWORD=admin123

# Optional: Payment gateway (mock/configurable)
PAYMENT_GATEWAY=mock

# Optional: Push notification (mock/configurable)
NOTIFICATION_PROVIDER=mock
